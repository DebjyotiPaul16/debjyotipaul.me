---
---

<section id="contact" aria-label="Contact">
  <!-- Noise background texture via SVG filter -->
  <div class="contact-noise" aria-hidden="true">
    <svg width="0" height="0">
      <filter id="noise-filter">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
        <feColorMatrix type="saturate" values="0"/>
      </filter>
    </svg>
    <div class="noise-overlay"></div>
  </div>

  <div class="contact-inner">
    <div class="contact-content">
      <div class="section-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        <span>Contact</span>
      </div>

      <h2 class="contact-heading" data-contact-heading>
        Let's Build<br />Something Great
      </h2>

      <p class="contact-subtext">
        Open to new opportunities, collaborations, and interesting conversations.
        Based in Bengaluru — working globally.
      </p>

      <div class="contact-links">
        <a
          href="mailto:connect@debjyotipaul.me"
          class="contact-email"
          data-cursor="open"
        >
          connect@debjyotipaul.me
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>

        <a
          href="tel:+919007736414"
          class="contact-phone"
          data-cursor="open"
        >
          +91 900 773 6414
        </a>

        <a
          href="https://www.debjyotipaul.me"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-phone"
          data-cursor="open"
        >
          www.debjyotipaul.me
        </a>
      </div>

      <div class="contact-actions">
        <a
          href="https://www.linkedin.com/in/debjyoti-paul-2b4b05a5"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
          data-magnetic
          data-cursor="open"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          Connect on LinkedIn
        </a>
      </div>
    </div>

    <div class="contact-footer">
      <p class="footer-text">
        &copy; {new Date().getFullYear()} Debjyoti Paul &mdash; Bengaluru, India
      </p>
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/debjyoti-paul-2b4b05a5" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #contact {
    padding-block: clamp(6rem, 14vh, 10rem);
    border-top: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .contact-noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .noise-overlay {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.06;
  }

  .contact-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .section-eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-light);
  }

  .eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background-color: var(--color-accent);
  }

  .contact-heading {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .contact-subtext {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    line-height: 1.7;
    color: var(--color-muted-light);
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .contact-email {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-email:hover {
    color: var(--color-accent-light);
  }

  .contact-phone {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-phone:hover {
    color: var(--color-muted-light);
  }

  .contact-actions {
    margin-bottom: 4rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2rem;
    background-color: var(--color-accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color 0.2s ease;
    will-change: transform;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-light);
    color: var(--color-bg);
  }

  .contact-footer {
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
  }

  .footer-links a {
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-accent-light);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', () => {
    document.fonts.ready.then(() => {
      const heading = document.querySelector<HTMLElement>('[data-contact-heading]');
      if (!heading) return;

      const splitHeading = new SplitText(heading, { type: 'chars' });
      gsap.from(splitHeading.chars, {
        opacity: 0,
        y: 60,
        rotationX: -60,
        stagger: 0.04,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: heading,
          start: 'top 80%',
        },
      });

      const subElements = document.querySelectorAll('.contact-subtext, .contact-links, .contact-actions');
      gsap.from(subElements, {
        opacity: 0,
        y: 30,
        stagger: 0.15,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: heading,
          start: 'top 70%',
        },
      });
    });
  });
</script>
